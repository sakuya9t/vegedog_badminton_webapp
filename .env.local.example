# ─────────────────────────────────────────────────────────────────────────────
# Local development — Supabase CLI (default)
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to `.env.local` (gitignored). After `supabase start` from the
# repo root, run `supabase status -o env` — it prints ANON_KEY=... and
# SERVICE_ROLE_KEY=... in JWT format. Paste those values below.
# (The CLI's table output uses different labels: Publishable = anon,
# Secret = service_role. Either format works; we standardize on the JWT form.)
#
# See docs/development.md for the full walkthrough.

NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<paste ANON_KEY from `supabase status -o env`>
# Service-role key. Server-side only; never expose in client code.
# Required by the admin client and the test-user seed script.
SUPABASE_SERVICE_ROLE_KEY=<paste SERVICE_ROLE_KEY from `supabase status -o env`>

# Where the app is reachable. Used by API routes to build session links.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────────
# Email (optional locally — disabled by default)
# ─────────────────────────────────────────────────────────────────────────────
# All email-sending API routes short-circuit when ENABLE_EMAIL != "true".
# Leave commented out unless you're testing the email features.

# ENABLE_EMAIL=true
# GMAIL_USER=you@gmail.com
# GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx   # Google Account → Security → App Passwords
# COURT_EMAIL=court@example.com            # comma-separated for multiple recipients

# ─────────────────────────────────────────────────────────────────────────────
# E2E tests (Playwright) — optional
# ─────────────────────────────────────────────────────────────────────────────
# Create a dedicated test account first (see `npm run seed:users`).

# TEST_USER_EMAIL=test@example.com
# TEST_USER_PASSWORD=your-test-password
